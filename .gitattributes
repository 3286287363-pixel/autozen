# Auto-detect text files and perform LF normalization
* text=auto

# Force LF for source files
*.kt text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.properties text eol=lf
*.gradle text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.apk binary
*.keystore binary
